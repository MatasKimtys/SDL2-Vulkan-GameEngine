{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Game",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [
                {
                    "name": "VULKAN_SDK",
                    "value": "C:/VulkanSDK/1.4.350.0"
                }
            ],
            "console": "integratedTerminal",
            "setupCommands":[
                {
                    "description": "Clear debuginfod URLs",
                    "text": "set debuginfod urls ",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
